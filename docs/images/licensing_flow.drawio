        <mxCell id="noteFlow" value="&lt;b&gt;Flow Summary&lt;/b&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1) Client / CLI → Agent: /v1/licenses/access&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;2) Agent checks Caffeine cache&lt;br&gt;   • miss → Service /access&lt;br&gt;   • hit → Service /access/validate&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;3) Generated client carries ServiceResponse&lt;br&gt;   and maps ProblemDetail errors&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;4) Service uses Redis + Keycloak&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;5) Agent returns LicenseToken or LicenseAgentErrorResponse&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;rounded=1;fillColor=#ffffff;strokeColor=#999999;align=left;" parent="1" vertex="1">
          <mxGeometry x="20" y="290" width="360" height="260" as="geometry" />
        </mxCell>

        <mxCell id="noteSecurity" value="&lt;b&gt;Security&lt;/b&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;• HTTP Basic (Client ⇄ Agent)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;• HTTP Basic (Agent ⇄ Service)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;• Detached signature (Agent → Service)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;• JWT EdDSA (Service)&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;rounded=1;fillColor=#ffffff;strokeColor=#999999;align=left;" parent="1" vertex="1">
          <mxGeometry x="420" y="370" width="420" height="180" as="geometry" />
